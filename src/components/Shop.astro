---
import Icon from "./icons.astro";
import { fetchShopProducts } from "../lib/fourthwall";

const products = await fetchShopProducts();
---
<section class="ww-section ww-shop-section" id="shop" aria-labelledby="shop-title">
  <div class="ww-container ww-shop__grid">
    <div class="ww-shop__copy">
      <p class="ww-kicker">The shop</p>
      <h2 id="shop-title">A few things worth carrying.</h2>
      <p>Small runs of Current Heading shirts, hats, bottles, and stickers.</p>
      <a class="ww-text-link" href="https://shop.currentheading.com" target="_blank" rel="noopener">
        Visit the shop <Icon kind="arrow" />
      </a>
    </div>

    <div class="ww-shop__products">
      {products.length > 0 ? (
        products.slice(0, 2).map((product) => (
          <a class="ww-shop__product" href={product.url} target="_blank" rel="noopener">
            {product.image && <img src={product.image} alt="" loading="lazy" decoding="async" />}
            <span><strong>{product.name}</strong><small>{product.price}</small></span>
          </a>
        ))
      ) : (
        <a class="ww-shop__fallback ww-text-link" href="https://shop.currentheading.com" target="_blank" rel="noopener">
          Browse the latest pieces <Icon kind="arrow" />
        </a>
      )}
    </div>
  </div>
</section>
