---
import Icon from "./icons.astro";

const beholdId = import.meta.env.BEHOLD_FEED_ID;
---
<section class="ww-section ww-instagram" id="instagram" aria-labelledby="instagram-title">
  <div class="ww-container">
    <div class="ww-section-intro ww-section-intro--split">
      <div>
        <p class="ww-kicker">On Instagram</p>
        <h2 id="instagram-title">More from the road, the lot, and the air.</h2>
      </div>
      <a href="https://instagram.com/currentheading" target="_blank" rel="noopener" class="ww-text-link">
        Follow @currentheading <Icon kind="arrow" />
      </a>
    </div>

    <div class="ww-ig__embed">
      {beholdId ? (
        <behold-widget feed-id={beholdId}></behold-widget>
      ) : (
        <div class="ww-empty-state">
          <p>The latest photographs are available on Instagram.</p>
          <a class="ww-text-link" href="https://instagram.com/currentheading" target="_blank" rel="noopener">
            View Instagram <Icon kind="arrow" />
          </a>
        </div>
      )}
    </div>
  </div>
</section>

{beholdId && <script src="https://w.behold.so/widget.js" type="module"></script>}
