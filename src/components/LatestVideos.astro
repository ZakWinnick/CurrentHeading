---
import Icon from "./icons.astro";
import { fetchLatestVideos } from "../lib/youtube";

const videos = await fetchLatestVideos(6);
---
<section class="ww-section" id="videos">
  <div class="ww-container">
    <div class="ww-eyebrow-row">
      <span class="ww-eyebrow"><span class="ww-idx">02</span> &nbsp; The Channel</span>
      <span class="ww-bar"></span>
      <span class="ww-eyebrow">youtube.com/@wyldwattage</span>
    </div>
    <div class="ww-videos__head">
      <h2 class="ww-display" style="font-size: var(--ww-h1); margin: 0; color: var(--ww-paper);">
        Latest from the road.
      </h2>
      <a href="https://youtube.com/@wyldwattage" target="_blank" rel="noopener">
        All videos on YouTube <Icon kind="arrow" />
      </a>
    </div>
    <div class="ww-videos__row">
      {videos.map((v, i) => (
        <a class="ww-video" href={v.url} target="_blank" rel="noopener">
          <div class="ww-video__thumb">
            {v.thumbnail ? (
              <img src={v.thumbnail} alt="" loading="lazy" decoding="async" width="640" height="360" />
            ) : (
              <div class="ww-ph">
                <div class="ww-ph__label">
                  <span class="num">VID/{String(i + 1).padStart(2, "0")}</span>
                  <span>{v.tag.toLowerCase()} thumb</span>
                </div>
              </div>
            )}
            <div class="ww-video__play"><Icon kind="play" /></div>
            {v.duration && <div class="ww-video__duration">{v.duration}</div>}
          </div>
          <div class="ww-video__meta">
            <span class="tag">{v.tag}</span>
            {v.views && <><span>·</span><span>{v.views} views</span></>}
          </div>
          <h3 class="ww-video__title">{v.title}</h3>
        </a>
      ))}
    </div>
  </div>
</section>
