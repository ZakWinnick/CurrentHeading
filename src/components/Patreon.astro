---
import Icon from "./icons.astro";
---
<section class="ww-section ww-support" id="support" aria-labelledby="support-title">
  <div class="ww-container ww-support__grid">
    <div>
      <p class="ww-kicker">Support the work</p>
      <h2 id="support-title">Help make the next trip possible.</h2>
      <p>
        Members help cover travel, production time, and the gear behind Current
        Heading. The Charging Hangar keeps the conversation going between releases.
      </p>
    </div>
    <div class="ww-support__action">
      <a class="ww-btn ww-btn--primary" href="https://members.currentheading.com" target="_blank" rel="noopener">
        See membership options <Icon kind="arrow" />
      </a>
      <span>Day-trip · Cross-country · Long-haul</span>
    </div>
  </div>
</section>
