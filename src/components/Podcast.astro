---
import Icon from "./icons.astro";
---
<section class="ww-section ww-podcast-section" id="podcast" aria-labelledby="podcast-title">
  <div class="ww-container ww-podcast">
    <div class="ww-podcast__art">
      <picture>
        <source
          type="image/avif"
          srcset="/images/ground-loop-cover-480.avif 480w, /images/ground-loop-cover-800.avif 800w"
          sizes="(min-width: 760px) 35vw, 100vw"
        />
        <source
          type="image/webp"
          srcset="/images/ground-loop-cover-480.webp 480w, /images/ground-loop-cover-800.webp 800w"
          sizes="(min-width: 760px) 35vw, 100vw"
        />
        <img
          src="/images/ground-loop-cover-800.webp"
          alt="Ground Loop podcast cover"
          width="800"
          height="800"
          loading="lazy"
          decoding="async"
        />
      </picture>
    </div>

    <div class="ww-podcast__copy">
      <p class="ww-kicker">Ground Loop podcast</p>
      <h2 id="podcast-title">The conversations that need more room.</h2>
      <p>
        The audio side of Current Heading, for the conversations that won't fit
        in a video. Longer takes on EVs, charging, aviation, and guests worth
        giving an hour to.
      </p>
      <a class="ww-text-link" href="https://podcast.currentheading.com" target="_blank" rel="noopener">
        Listen to Ground Loop <Icon kind="arrow" />
      </a>
      <iframe
        class="ww-podcast__player"
        src="https://player.fireside.fm/v3/cSzCML9e/latest?theme=dark"
        title="Ground Loop podcast player"
        loading="lazy"
        allow="autoplay"
      ></iframe>
    </div>
  </div>
</section>
