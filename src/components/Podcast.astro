---
import Icon from "./icons.astro";
---
<section class="ww-section" id="podcast">
  <div class="ww-container">
    <div class="ww-eyebrow-row">
      <span class="ww-eyebrow"><span class="ww-idx">04</span> &nbsp; The Podcast</span>
      <span class="ww-bar"></span>
      <span class="ww-eyebrow">Wyld Wramblings</span>
    </div>
    <div class="ww-podcast">
      <div class="ww-podcast__art">
        <img
          src="/images/wyldwramblings-cover.webp"
          alt="Wyld Wramblings podcast cover"
          width="1200"
          height="1200"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="ww-podcast__copy">
        <span class="ww-eyebrow" style="display: block; margin-bottom: 16px;">The audio companion</span>
        <h2 class="ww-display" style="font-size: var(--ww-h1); margin: 0; color: var(--ww-paper);">
          Voice memos<br />from the trailhead.
        </h2>
        <p style="margin-top: 24px;">
          The podcast we make when there's too much to say for a 12-minute video.
          Hotel rants after a bad plug, three-hour deep-dives on bid documents,
          and the occasional guest who actually knows what they're talking about.
        </p>

        {/* Placeholder. Wyld Wramblings hasn't launched yet. Update each href when the feed goes live. */}
        <ul class="ww-podcast__platforms">
          <li><a href="#" aria-label="Apple Podcasts (coming soon)"><Icon kind="apple" /> Apple Podcasts</a></li>
          <li><a href="#" aria-label="Spotify (coming soon)"><Icon kind="spotify" /> Spotify</a></li>
          <li><a href="#" aria-label="Overcast (coming soon)"><Icon kind="overcast" /> Overcast</a></li>
          <li><a href="#" aria-label="RSS (coming soon)"><Icon kind="rss" /> RSS</a></li>
        </ul>

        <div class="ww-podcast__latest">
          <div>
            <div class="ep-num">Coming soon</div>
            <div class="ep-title">First episode drops once the studio's wired up.</div>
          </div>
          <span class="ep-time">TBA</span>
        </div>
      </div>
    </div>
  </div>
</section>
