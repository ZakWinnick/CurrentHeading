---
import Icon from "./icons.astro";
---
<header class="ww-hero" id="top">
  <div class="ww-hero__bg" aria-hidden="true"></div>
  <div class="ww-hero__scrim" aria-hidden="true"></div>
  <div class="ww-hero__grain" aria-hidden="true"></div>

  <div class="ww-hero__content">
    <h1 class="ww-hero__headline">
      EVs, charging,<br />
      and the <em>view from<br />
      the cockpit.</em>
    </h1>

    <p class="ww-hero__sub">
      Ownership reality, DC fast charging reviewed from inside the industry,
      and dispatches from the air. One channel, three lanes, no sponsorship strings.
    </p>

    <div class="ww-hero__ctas">
      <a class="ww-btn ww-btn--primary" href="https://youtube.com/@currentheading" target="_blank" rel="noopener">
        Watch on YouTube
        <Icon kind="arrow" />
      </a>
      <a class="ww-btn ww-btn--ghost" href="https://members.currentheading.com" target="_blank" rel="noopener">
        Become a Patron
        <Icon kind="arrow" />
      </a>
    </div>
  </div>
</header>
