---
import Icon from "./icons.astro";
---
<header class="ww-hero" id="top">
  <div class="ww-hero__bg" aria-hidden="true"></div>
  <div class="ww-hero__scrim" aria-hidden="true"></div>
  <div class="ww-hero__grain" aria-hidden="true"></div>

  <div class="ww-hero__content">
    <h1 class="ww-hero__headline">
      DC fast charging,<br />
      reviewed by someone<br />
      who <em>builds it.</em>
    </h1>

    <p class="ww-hero__sub">
      Site reviews, network takes, road-trip diaries, and the occasional rant from a charging
      operator with skin in the asphalt.
    </p>

    <div class="ww-hero__ctas">
      <a class="ww-btn ww-btn--primary" href="https://youtube.com/@wyldwattage" target="_blank" rel="noopener">
        Watch on YouTube
        <Icon kind="arrow" />
      </a>
      <a class="ww-btn ww-btn--ghost" href="https://members.wyldwattage.com" target="_blank" rel="noopener">
        Become a Patron
        <Icon kind="arrow" />
      </a>
    </div>
  </div>
</header>
