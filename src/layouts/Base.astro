---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Current Heading. EVs, charging, and aviation.",
  description = "Films, photographs, and field notes from Zak Winnick across EV ownership, charging infrastructure, and aviation.",
} = Astro.props;

const canonical = "https://currentheading.com/";
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#11100f" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content="https://currentheading.com/" />
  <meta property="og:image" content="https://currentheading.com/images/og-card.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Current Heading. EV ownership, charging infrastructure, and aviation." />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@currentheading" />
  <meta name="twitter:image" content="https://currentheading.com/images/og-card.jpg" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=Manrope:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
  />

  <script src="https://tinylytics.app/embed/vQ5FDyywb7SypJ7Wqr5-.js" defer></script>
</head>
<body>
  <slot />
</body>
</html>
