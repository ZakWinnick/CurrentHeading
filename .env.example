# YouTube Data API v3 — read at build time (Astro) to fetch latest videos
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Behold widget for Instagram embed (https://behold.so)
BEHOLD_FEED_ID=

# Fourthwall Storefront API — read at request time by /functions/api/shop.ts
# Use the public storefront token (the "ptkn_..." form).
FOURTHWALL_PUBLIC_TOKEN=
FOURTHWALL_COLLECTION_SLUG=all
FOURTHWALL_SHOP_HOST=shop.currentheading.com

# Patreon API v2 — Creator's access token from the dev portal.
# Used at build time to pull live patron count. Default lifetime ~31 days.
PATREON_ACCESS_TOKEN=
